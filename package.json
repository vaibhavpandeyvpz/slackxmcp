{
  "name": "slackmcp",
  "version": "0.1.0",
  "description": "TypeScript stdio MCP server and CLI for Slack Socket Mode apps.",
  "type": "module",
  "bin": {
    "slackmcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-instructions.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "slack",
    "socket-mode",
    "bolt",
    "cli",
    "typescript"
  ],
  "author": "Vaibhav Pandey <contact@vaibhavpandey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/slackmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/slackmcp/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/slackmcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
