{
  "name": "slackxmcp",
  "version": "0.4.6",
  "description": "TypeScript stdio MCP server and CLI for Slack Socket Mode apps.",
  "type": "module",
  "bin": {
    "slackxmcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-instructions.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "slack",
    "socket-mode",
    "bolt",
    "cli",
    "typescript"
  ],
  "author": "Vaibhav Pandey <contact@vaibhavpandey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/slackxmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/slackxmcp/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/slackxmcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
